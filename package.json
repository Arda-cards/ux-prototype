{
  "name": "@arda-cards/design-system",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./canary": {
      "types": "./dist/canary.d.ts",
      "import": "./dist/canary.js",
      "require": "./dist/canary.cjs"
    },
    "./extras": {
      "types": "./dist/extras.d.ts",
      "import": "./dist/extras.js",
      "require": "./dist/extras.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./types/canary": {
      "types": "./dist/types-canary.d.ts",
      "import": "./dist/types-canary.js",
      "require": "./dist/types-canary.cjs"
    },
    "./types/extras": {
      "types": "./dist/types-extras.d.ts",
      "import": "./dist/types-extras.js",
      "require": "./dist/types-extras.cjs"
    },
    "./types/date-time": {
      "types": "./dist/types-date-time.d.ts",
      "import": "./dist/types-date-time.js",
      "require": "./dist/types-date-time.cjs"
    },
    "./types/canary-date-time": {
      "types": "./dist/types-canary-date-time.d.ts",
      "import": "./dist/types-canary-date-time.js",
      "require": "./dist/types-canary-date-time.cjs"
    },
    "./types/extras-date-time": {
      "types": "./dist/types-extras-date-time.d.ts",
      "import": "./dist/types-extras-date-time.js",
      "require": "./dist/types-extras-date-time.cjs"
    },
    "./styles": "./dist/styles/globals.css",
    "./styles/*": "./dist/styles/*",
    "./assets/*": "./dist/assets/*"
  },
  "typesVersions": {
    "*": {
      "canary": [
        "./dist/canary.d.ts"
      ],
      "extras": [
        "./dist/extras.d.ts"
      ],
      "types": [
        "./dist/types.d.ts"
      ],
      "types/canary": [
        "./dist/types-canary.d.ts"
      ],
      "types/extras": [
        "./dist/types-extras.d.ts"
      ],
      "types/date-time": [
        "./dist/types-date-time.d.ts"
      ],
      "types/canary-date-time": [
        "./dist/types-canary-date-time.d.ts"
      ],
      "types/extras-date-time": [
        "./dist/types-extras-date-time.d.ts"
      ]
    }
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "install:vendored": "node tools/install-vendored-deps.js",
    "build-storybook": "node tools/install-vendored-deps.js && storybook build",
    "build:lib": "LIB_BUILD=true vite build && node tools/copy-dist-assets.js",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "coverage:summary": "npx vitest --run --coverage 2>&1 | tail -5",
    "test:storybook": "test-storybook --testTimeout 30000 --skipTags skip-ci",
    "test:storybook:ci": "concurrently -k -s first \"http-server storybook-static --port 6006 --silent\" \"wait-on tcp:6006 && test-storybook --testTimeout 30000 --skipTags skip-ci\"",
    "test:vrt": "playwright test --project=vrt",
    "test:vrt:ci": "concurrently -k -s first \"http-server storybook-static --port 6006 --silent\" \"wait-on tcp:6006 && playwright test --project=vrt\"",
    "test:vrt:update": "concurrently -k -s first \"http-server storybook-static --port 6006 --silent\" \"wait-on tcp:6006 && playwright test --project=vrt --update-snapshots\"",
    "serve": "node tools/server.js"
  },
  "dependencies": {
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "heic2any": "^0.0.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-easy-crop": "^5.5.7",
    "tailwind-merge": "^3.4.0"
  },
  "peerDependencies": {
    "ag-grid-community": "^34.0.0",
    "ag-grid-react": "^34.0.0",
    "lucide-react": ">=0.400.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/react-vite": "^10.3.1",
    "@storybook/test-runner": "^0.24.3",
    "@tailwindcss/postcss": "^4.1.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "ag-grid-community": "^35.2.0",
    "ag-grid-react": "^35.2.0",
    "agentation": "^3.0.2",
    "concurrently": "^9.1.0",
    "eslint": "^10",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.2.0",
    "eslint-plugin-storybook": "^10.3.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "http-server": "^14.1.1",
    "jsdom": "^29.0.1",
    "lucide-react": "^1.7.0",
    "msw": "^2.12.10",
    "msw-storybook-addon": "^2.0.6",
    "pako": "^2.1.0",
    "prettier": "^3.4.0",
    "qr-scanner": "^1.4.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "react-icons": "^5.6.0",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "sonner": "^2.0.7",
    "storybook": "^10.3.1",
    "tailwindcss": "^4.1.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
