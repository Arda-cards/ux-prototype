# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/tests/test-results/
/tests/vrt/test-results/

# production
/dist
/build

# storybook
/storybook-static

# misc
.DS_Store
*.pem

# scratch workspace
/scratch

# vendored files — local fixes only, changes go upstream to arda-frontend-app
/src/vendored/

# agent/AI tool skills and config
.agent/
.agents/
.claude/
.windsurf/
skills/
skills-lock.json

# debug
npm-debug.log*
debug-storybook.log
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
